# Claude Usage Bar — user config
# Copy to ~/.config/claude-usage-bar/config.sh and tune for your plan.
#
# Anthropic does not publish exact token caps; these are community-observed
# ceilings for the Claude Max ($100) plan. Watch your bar over a few days and
# adjust so 100% matches the point where Claude Code actually rate-limits you.

# 5-hour block token ceiling
BLOCK_TOKEN_LIMIT=220000000   # 220M

# Weekly token ceiling
WEEKLY_TOKEN_LIMIT=1000000000 # 1B
